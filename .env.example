# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Django
SECRET_KEY=your-secret-key-here-generate-with-python-secrets
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# DeepSeek AI (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Database (leave blank to use SQLite locally)
# On Render/Railway, set this to the PostgreSQL connection string
# DATABASE_URL=postgresql://user:password@host:5432/dbname
